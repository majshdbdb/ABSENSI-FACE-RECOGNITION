# Salin file ini jadi ".env" untuk development lokal (opsional).
# Di Railway, atur variable ini lewat tab Variables di dashboard, bukan file .env.

PORT=5000

# Kosongkan/hapus baris ini untuk pakai file lokal ./attendance.db (cukup untuk testing).
# Di Railway (production), isi dengan path folder Volume yang kamu mount, contoh: /data/attendance.db
# DB_PATH=/data/attendance.db

# Berapa lama sesi login admin/kiosk bertahan sebelum harus login ulang (jam).
SESSION_HOURS=18

# ---- Geofencing (opsional) ----
# Kalau true, login HANYA bisa dilakukan dari perangkat yang lokasinya dekat sekolah.
# WAJIB isi SCHOOL_LAT & SCHOOL_LNG kalau ini diaktifkan, atau geofence otomatis dianggap nonaktif.
GEOFENCE_ENABLED=false

# Koordinat sekolah -- cara dapetinnya: buka Google Maps, cari lokasi sekolah,
# klik-kanan titik yang tepat di gedung sekolah, klik angka koordinat yang muncul di menu
# (formatnya "lat, lng", copy 2 angkanya ke sini terpisah).
SCHOOL_LAT=
SCHOOL_LNG=

# Radius toleransi dalam meter. Longgarkan kalau perangkat yang dipakai (laptop/PC)
# gak punya chip GPS asli -- akurasi lokasi lewat WiFi/IP kadang meleset ratusan meter.
GEOFENCE_RADIUS_M=300
